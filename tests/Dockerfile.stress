FROM python:3.12-slim

RUN apt-get update && apt-get install -y --no-install-recommends procps \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

RUN pip install --no-cache-dir flask>=3.0 cryptography>=41.0 psutil

COPY desktop/shared/ /app/desktop/shared/
COPY firmware/registry.json /app/firmware/registry.json
COPY tests/test_stress.py /app/tests/test_stress.py

CMD ["python", "-u", "tests/test_stress.py"]
